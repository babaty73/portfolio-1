.env
 MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/portfolio

# Email (use a Gmail App Password — not your actual Gmail password)
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-app-password
EMAIL_TO=your@gmail.com

# CORS — set this to your deployed Vercel domain in production
CLIENT_ORIGIN=https://your-portfolio.vercel.app

# Server
PORT=4000